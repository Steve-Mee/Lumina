TRADER_LEAGUE_DATABASE_URL=sqlite:///trader_league.db
TRADER_LEAGUE_CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# Path to repo-root config.yaml when starting uvicorn from the lumina_os/ folder
LUMINA_CONFIG=../config.yaml

# Required for startup (min. 32 characters). Matches security.jwt_secret_key: "${LUMINA_JWT_SECRET_KEY}" in config.yaml.
LUMINA_JWT_SECRET_KEY=LUMINA_LOCAL_DEVELOPMENT_JWT_SECRET_KEY_32

# Optional; default 8000. Set if another process already uses 8000 (e.g. vLLM).
# LUMINA_BACKEND_PORT=8001
