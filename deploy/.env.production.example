TZ=UTC
PYTHONUNBUFFERED=1
LUMINA_MAX_RESTARTS=5
LUMINA_HEALTH_MAX_AGE=120
LUMINA_ENTRYPOINT=lumina_v45.1.1.py
LUMINA_STATE_FILE=/app/state/lumina_sim_state.json
LUMINA_BIBLE_FILE=/app/state/lumina_daytrading_bible.json
LUMINA_THOUGHT_LOG=/app/state/lumina_thought_log.jsonl
LUMINA_LOG_FILE=/app/logs/lumina_full_log.csv
JOURNAL_DIR=/app/journal

# Auto-update policy
LUMINA_UPDATE_MODE=tag
LUMINA_RELEASE_PREFIX=v
LUMINA_RELEASE_REF=
LUMINA_UPDATE_BRANCH=main
LUMINA_AUTO_UPDATE_INTERVAL=30min

# Optional model / inference credentials
HUGGING_FACE_HUB_TOKEN=
XAI_KEY=

# Optional broker / exchange / app secrets
NT_ACCOUNT_ID=
NT_API_KEY=
NEWS_API_KEY=
