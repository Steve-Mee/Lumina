{
  "include": [
    "lumina_core",
    "lumina_os",
    "lumina_bible",
    "lumina_agents",
    "scripts",
    "tests"
  ],
  "extraPaths": [
    "lumina_os"
  ],
  "pythonVersion": "3.11",
  "typeCheckingMode": "standard",
  "reportMissingImports": false,
  "reportMissingModuleSource": false,
  "exclude": [
    "**/.venv",
    "**/__pycache__",
    "logs",
    "state",
    "journal",
    "lumina_vector_db"
  ]
}
